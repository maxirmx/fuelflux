#!/bin/bash
set -euo pipefail

case "${1:-}" in
  configure)
    if [[ ! -x /opt/fuelflux/deploy/install.sh ]]; then
      echo "Error: /opt/fuelflux/deploy/install.sh is missing or not executable" >&2
      exit 1
    fi
    if ! /opt/fuelflux/deploy/install.sh install /opt/fuelflux/bin/fuelflux; then
      echo "Error: failed to run deploy install script during package configure" >&2
      exit 1
    fi
    if ! /opt/fuelflux/deploy/install.sh start; then
      echo "Error: failed to start fuelflux service during package configure" >&2
      exit 1
    fi
    ;;
  abort-upgrade|abort-remove|abort-deconfigure)
    # No action needed for abort states.
    ;;
esac
